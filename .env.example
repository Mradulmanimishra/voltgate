# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Router Auth ────────────────────────────────────────────
# Bearer token clients must send. Empty = open/dev mode.
ROUTER_API_KEY=your-secret-router-key-here

# ── Rate Limiting ──────────────────────────────────────────
MAX_RPM=60
MAX_SPEND_PER_HOUR_USD=10.0

# ── Spend Alerts ─────────────────────────────────────────────
# Slack-compatible webhook URL. Fires at 80% and 100% of hourly spend.
# Leave empty to disable.
SPEND_ALERT_WEBHOOK_URL=

# ── Server ─────────────────────────────────────────────────
PORT=3001
DB_PATH=router.db
CONFIG_PATH=config.toml

# ── Logging ────────────────────────────────────────────────
RUST_LOG=llm_router=info,tower_http=info
