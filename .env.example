# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Router Auth ────────────────────────────────────────────
# Bearer token clients must send. Empty = open/dev mode.
ROUTER_API_KEY=your-secret-router-key-here

# ── Rate Limiting ──────────────────────────────────────────
MAX_RPM=60
MAX_SPEND_PER_HOUR_USD=10.0

# ── Spend Alerts ─────────────────────────────────────────────
# Slack-compatible webhook URL. Fires at 80% and 100% of hourly spend.
# Leave empty to disable.
SPEND_ALERT_WEBHOOK_URL=

# ── Server ─────────────────────────────────────────────────
PORT=3001
DB_PATH=router.db
CONFIG_PATH=config.toml
# ── Embeddings ─────────────────────────────────────────────
# Voyage AI API key for real text embeddings. Leave empty for
# deterministic mock embeddings (development/testing).
VOYAGE_API_KEY=

# ── Distributed Rate Limiting ──────────────────────────────
# Redis URL for shared rate-limiting across multiple instances.
# Leave empty to use in-memory (single instance only).
REDIS_URL=

# ── Logging ────────────────────────────────────────────────
RUST_LOG=voltgate=info,tower_http=info
